{{!-- Move Attributes Tab --}}
<section class="tab {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
  {{#if owned}}
  {{#unless system.attributes.maneuver}}
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrLearned"}}</label>
    <input type="checkbox" name="system.learned" {{checked system.learned}} data-dtype="Boolean">
  </div>

  {{#unless system.learned}}
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrLearnedAtRank"}}</label>
    <select name="system.rank" value="{{system.rank}}" data-dtype="String">
      {{selectOptions ranks selected=system.rank}}
    </select>
  </div>
  {{/unless}}

  {{#if system.learned}}
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrOverrank"}}</label>
    <input type="checkbox" name="system.overrank" {{checked system.overrank}} data-dtype="Boolean">
  </div>
  {{/if}}

  <hr>
  {{/unless}}
  {{/if}}

  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrType"}}</label>
    <select name="system.type" value="{{system.type}}" data-dtype="String">
      {{selectOptions types selected=system.type}}
    </select>
  </div>
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrCategory"}}</label>
    <select name="system.category" value="{{system.category}}" data-dtype="String">
      {{selectOptions categories selected=system.category}}
    </select>
  </div>
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrTarget"}}</label>
    <select name="system.target" value="{{system.target}}" data-dtype="String">
      {{selectOptions targets selected=system.target}}
    </select>
  </div>
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrPower"}}</label>
    <input type="text" name="system.power" value="{{system.power}}" data-dtype="Number"/>
  </div>
  <div class="form-group alternative-stat">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrAccAttr"}}</label>
    <input type="text" name="system.accAttr1" value="{{system.accAttr1}}" data-dtype="String">
    <label>/</label>
    <input type="text" name="system.accAttr1var" value="{{system.accAttr1var}}" data-dtype="String">
  </div>
  <div class="form-group alternative-stat">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrAccSkill"}}</label>
    <input type="text" name="system.accSkill1" value="{{system.accSkill1}}" data-dtype="String">
    <label>/</label>
    <input type="text" name="system.accSkill1var" value="{{system.accSkill1var}}" data-dtype="String">
  </div>
  <div class="form-group">
    <label class="resource-label alternative-stat">{{localize "POKEROLE.MoveAttrDmgMod"}}</label>
    <input type="text" name="system.dmgMod1" value="{{system.dmgMod1}}" data-dtype="String">
    <label>/</label>
    <input type="text" name="system.dmgMod1var" value="{{system.dmgMod1var}}" data-dtype="String">
  </div>
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrAddedEffect"}}</label>
    <textarea name="system.effect" data-dtype="String">{{system.effect}}</textarea>
  </div>

  <hr>

  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrAccuracyReduction"}}</label>
    <input type="text" name="system.attributes.accuracyReduction" value="{{system.attributes.accuracyReduction}}" data-dtype="Number"/>
  </div>
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrManeuver"}}</label>
    <input type="checkbox" name="system.attributes.maneuver" {{checked system.attributes.maneuver}} data-dtype="Boolean">
  </div>
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrNeverFail"}}</label>
    <input type="checkbox" name="system.attributes.neverFail" {{checked system.attributes.neverFail}} data-dtype="Boolean">
  </div>
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrIgnoreDefenses"}}</label>
    <input type="checkbox" name="system.attributes.ignoreDefenses" {{checked system.attributes.ignoreDefenses}} data-dtype="Boolean">
  </div>
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrRecoil"}}</label>
    <input type="checkbox" name="system.attributes.recoil" {{checked system.attributes.recoil}} data-dtype="Boolean">
  </div>
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrResistedWithDefense"}}</label>
    <input type="checkbox" name="system.attributes.resistedWithDefense" {{checked system.attributes.resistedWithDefense}} data-dtype="Boolean">
  </div>


  <hr>

  {{!-- Heal --}}
  <h3>{{localize "POKEROLE.MoveHpHeal"}}</h3>

  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveHealType"}}</label>
    <select name="system.heal.type" value="{{system.heal.type}}" data-dtype="String">
      {{selectOptions healTypes selected=system.heal.type}}
    </select>
  </div>

  {{#if healEnabled}}
  {{#unless isLeechHeal}}
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrTarget"}}</label>
    <select name="system.heal.target" value="{{system.heal.target}}" data-dtype="String">
      {{selectOptions effectTargets selected=system.heal.target}}
    </select>
  </div>

  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveHealWillPointCost"}}</label>
    <input type="text" name="system.heal.willPointCost" value="{{system.heal.willPointCost}}" data-dtype="Number"/>
  </div>
  {{/unless}}
  {{/if}}

  {{#if isCustomHeal}}
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveHealedHp"}}</label>
    <input type="text" name="system.heal.amount" value="{{system.heal.amount}}" data-dtype="Number"/>
  </div>
  {{/if}}

  {{#if isLeechHeal}}
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveLeechPercentage"}}</label>
    <input type="text" name="system.heal.amount" value="{{system.heal.amount}}" data-dtype="Number" min="0" max="1"/>
  </div>
  {{/if}}

  <hr>

  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.MoveAttrSource"}}</label>
    <input type="text" name="system.source" value="{{system.source}}" data-dtype="String"/>
  </div>
</section>
