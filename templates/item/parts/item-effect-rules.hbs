{{!-- Effect Rules Tab --}}
<section class="tab {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.EffectRuleEnable"}}</label>
    <input type="checkbox" name="system.enabled" {{checked system.enabled}} data-dtype="Boolean">
    </select>
  </div>
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.EffectRuleShow"}}</label>
    <input type="checkbox" name="system.visible" {{checked system.visible}} data-dtype="Boolean">
    </select>
  </div>
  <div class="form-group">
    <label class="resource-label">{{localize "POKEROLE.EffectRuleSource"}}</label>
    <input type="text" name="system.source" value="{{system.source}}" data-dtype="String"/>
  </div>

  <hr>

  <h3>{{localize "POKEROLE.EffectRuleCustomTitle"}}</h3>
  <p>{{localize "POKEROLE.EffectRuleCustomWarning"}}</p>

  <ol class="items-list effects-list">
    <li class="item flexrow items-header">
      <div>{{localize "POKEROLE.EffectRuleAttrKey"}}</div>
      <div>{{localize "POKEROLE.EffectRuleChangeMode"}}</div>
      <div>{{localize "POKEROLE.EffectRuleValue"}}</div>
      <div class="item-controls">
        <a class="item-control" title="{{localize 'POKEROLE.EffectRuleAdd'}}" data-action="addRule" data-type="rule"><i class="fas fa-plus"></i>{{localize "POKEROLE.EffectRuleAdd"}}</a>
      </div>
    </li>
    {{#each system.rules as |rule i|}}
    <li class="flexrow">
      <input class="rule-attribute" data-index="{{i}}" type="text" value="{{rule.attribute}}" placeholder="system.attributes.strength.value" data-dtype="String"/>
      <select class="rule-operator" data-index="{{i}}" value="{{rule.operator}}" data-dtype="String">
        {{selectOptions ../operators selected=rule.operator}}
      </select>
      <input type="number" class="rule-value" value="{{rule.value}}" data-index="{{i}}" data-dtype="Number"/>
      <div class="item-controls">
        <a class="item-control" title="{{localize 'POKEROLE.EffectRuleDelete'}}" data-action="deleteRule" data-index="{{i}}"><i class="fas fa-trash"></i></a>
      </div>
    </li>
    {{/each}}
  </ol>
</section>
